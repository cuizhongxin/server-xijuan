<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tencent.wxcloudrun.dao.EquipmentPreMapper">

    <resultMap id="equipmentPreMap" type="com.tencent.wxcloudrun.model.EquipmentPre">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="color" property="color"/>
        <result column="type" property="type"/>
        <result column="position" property="position"/>
        <result column="need_level" property="needLevel"/>
        <result column="max_level" property="maxLevel"/>
        <result column="suit_id" property="suitId"/>
        <result column="suit_name" property="suitName"/>
        <result column="base_price" property="basePrice"/>
        <result column="icon_url" property="iconUrl"/>
        <result column="gen_att" property="genAtt"/>
        <result column="gen_def" property="genDef"/>
        <result column="gen_for" property="genFor"/>
        <result column="gen_leader" property="genLeader"/>
        <result column="army_life" property="armyLife"/>
        <result column="army_att" property="armyAtt"/>
        <result column="army_def" property="armyDef"/>
        <result column="army_sp" property="armySp"/>
        <result column="army_hit" property="armyHit"/>
        <result column="army_mis" property="armyMis"/>
    </resultMap>

    <select id="findById" resultMap="equipmentPreMap">
        SELECT * FROM equipment_pre WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="equipmentPreMap">
        SELECT * FROM equipment_pre ORDER BY color, need_level, id
    </select>

    <select id="findByColor" resultMap="equipmentPreMap">
        SELECT * FROM equipment_pre WHERE color = #{color} ORDER BY need_level, id
    </select>

    <select id="findBySuitId" resultMap="equipmentPreMap">
        SELECT * FROM equipment_pre WHERE suit_id = #{suitId} ORDER BY type
    </select>

    <select id="findByNeedLevel" resultMap="equipmentPreMap">
        SELECT * FROM equipment_pre WHERE need_level &lt;= #{needLevel} ORDER BY need_level DESC, color DESC, id
    </select>

    <select id="findByIds" resultMap="equipmentPreMap">
        SELECT * FROM equipment_pre WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY id
    </select>

    <select id="findBySetName" resultMap="equipmentPreMap">
        SELECT * FROM equipment_pre WHERE suit_name = #{setName} ORDER BY id
    </select>

</mapper>
